# Database
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=123456
DATABASE_NAME=social-network-SNet

# Access token
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_EXPIRE=432000000

# Rate limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0

# Redis
BULLMQ_HOST=localhost
BULLMQ_PORT=6379
BULLMQ_PASSWORD=123456
BULLMQ_DB=1

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# SMTP (gửi email OTP đăng ký & quên mật khẩu)
# Ví dụ dùng Gmail: bật 2FA rồi tạo "App Password" (16 ký tự) làm SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Node
NODE_ENV=development
PORT=3000
HOST=http://localhost:3000/



# FastAPI
FASTAPI_HOST=localhost
FASTAPI_PORT=8000
API_PREFIX=''
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_KEY=key_auth

# ===== AI SERVICES (FASTAPI) =====
JWT_ALGORITHM=HS256
CHROMA_DB_HOST=chromadb
CHROMA_DB_PORT=8000
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
PORT_NEST=3000
HOST_NEST=backend_nestjs
KEY_AUTH=key_auth
PORT_FASTAPI=8000
HOST_FASTAPI=0.0.0.0

